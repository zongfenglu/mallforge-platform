# MallForge Environment Variables
# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ── 数据库 ──────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=your_strong_mysql_password

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=your_strong_redis_password

# ── JWT ─────────────────────────────────────────────────────
# 必须至少 32 个字符
JWT_SECRET=mallforge-replace-this-with-a-real-secret-key-min-32-chars

# ── 支付配置加密密钥（16/24/32 字节）────────────────────────
PAYMENT_AES_KEY=mallforge-payment-aes-key-16byte

# ── 微信支付（租户在管理后台配置，此处留空）─────────────────
# WECHAT_APP_ID=
# WECHAT_MCH_ID=

# ── 应用域名 ─────────────────────────────────────────────────
ADMIN_DOMAIN=admin.yourdomain.com
API_DOMAIN=api.yourdomain.com
